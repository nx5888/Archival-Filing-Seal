{
  "version": "2026.2",
  "name": "会计档案归档章",
  "description": "4格归档章，适用于会计档案",
  "position": {
    "anchor": "top-right",
    "offset_mm": [5, 5],
    "page_scope": "first-only"
  },
  "stamp_size_mm": [30, 12],
  "cells": [
    { "id": "fonds_code",  "label": "全宗号",    "row": 0, "col": 0, "source": "config",               "required": true  },
    { "id": "year",        "label": "年度",      "row": 0, "col": 1, "source": "path",      "path_level": 0, "required": true  },
    { "id": "voucher",    "label": "凭证字号",  "row": 1, "col": 0, "source": "filename",  "regex_group": "voucher", "required": true  },
    { "id": "seq_num",    "label": "顺序号",    "row": 1, "col": 1, "source": "filename",  "regex_group": "seq",      "required": true  }
  ],
  "field_registry": [
    { "field_name": "fonds_code", "label": "全宗号",    "default_source": "config",          "required": true  },
    { "field_name": "year",       "label": "年度",      "default_source": "path",            "required": true  },
    { "field_name": "voucher",    "label": "凭证字号",  "default_source": "filename",        "required": true  },
    { "field_name": "seq_num",    "label": "顺序号",    "default_source": "filename",        "required": true  },
    { "field_name": "month",      "label": "月份",      "default_source": "path",            "required": false },
    { "field_name": "page_count", "label": "页数",      "default_source": "pdf_metadata",   "required": true  }
  ],
  "font": { "family": "SimFang", "size_pt": 9, "fallback": "SimSun" },
  "border": { "width_pt": 0.5, "color": [0, 0, 0] },
  "page_number": {
    "enabled": true, "scope": "all-pages", "numbering_mode": "per-file",
    "start_number": 1, "format": "{current}", "zero_pad": 0,
    "font_family": "SimFang", "font_size_pt": 8, "font_color": [0,0,0],
    "bold": false, "italic": false, "opacity": 100,
    "position_v": "bottom", "position_h": "center", "mirror_odd_even": false, "offset_mm": [0, 10]
  }
}
