{
  "version": "2026.2",
  "name": "T22-2015 文书档案归档章",
  "description": "6格归档章，适用于文书档案",
  "position": {
    "anchor": "top-right",
    "offset_mm": [5, 5],
    "page_scope": "first-only"
  },
  "stamp_size_mm": [30, 15],
  "cells": [
    { "id": "fonds_code",  "label": "全宗号",    "row": 0, "col": 0, "source": "config",               "required": true  },
    { "id": "year",        "label": "年度",      "row": 0, "col": 1, "source": "path",      "path_level": 0, "required": true  },
    { "id": "doc_num",     "label": "件号",      "row": 1, "col": 0, "source": "filename",  "regex_group": "docnum", "required": true  },
    { "id": "issue",       "label": "机构或问题","row": 1, "col": 1, "source": "filename",  "regex_group": "org",   "required": false },
    { "id": "retention",   "label": "保管期限",  "row": 2, "col": 0, "source": "config_or_path", "path_level": 1, "required": true  },
    { "id": "page_count",  "label": "页数",      "row": 2, "col": 1, "source": "pdf_metadata",              "required": true  }
  ],
  "field_registry": [
    { "field_name": "fonds_code", "label": "全宗号",    "default_source": "config",          "required": true  },
    { "field_name": "year",       "label": "年度",      "default_source": "path",            "required": true  },
    { "field_name": "doc_num",    "label": "件号",      "default_source": "filename",        "required": true  },
    { "field_name": "org",        "label": "机构或问题", "default_source": "filename",        "required": false },
    { "field_name": "retention",  "label": "保管期限",  "default_source": "config_or_path",  "required": true  },
    { "field_name": "page_count", "label": "页数",      "default_source": "pdf_metadata",   "required": true  }
  ],
  "font": {
    "family": "SimFang",
    "size_pt": 9,
    "fallback": "SimSun"
  },
  "border": {
    "width_pt": 0.5,
    "color": [0, 0, 0]
  },
  "page_number": {
    "enabled": true,
    "scope": "all-pages",
    "skip_first": false,
    "page_range": null,
    "numbering_mode": "per-file",
    "start_number": 1,
    "format": "{current}",
    "zero_pad": 0,
    "font_family": "SimFang",
    "font_size_pt": 8,
    "font_color": [0, 0, 0],
    "bold": false,
    "italic": false,
    "opacity": 100,
    "position_v": "bottom",
    "position_h": "center",
    "mirror_odd_even": false,
    "offset_mm": [0, 10]
  }
}
